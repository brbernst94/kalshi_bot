# ── Kalshi Credentials ────────────────────────────────────────────────────────
# Get these from: https://kalshi.com/account/profile → API Keys

# The UUID shown as "Key ID" after generating an API key
KALSHI_API_KEY_ID=your-key-id-uuid-here

# Your RSA private key — either:
#   Option A: paste the full PEM inline (use \n for newlines):
#   KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
#
#   Option B: path to the .key file Kalshi downloads automatically:
#   KALSHI_PRIVATE_KEY=/path/to/kalshi-key.key

KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nPASTE_YOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----

# Set to "true" to use demo-api.kalshi.co (paper trading — recommended first!)
USE_DEMO=true
